{
  "name": "codex-ui",
  "version": "0.1.0",
  "description": "React UI components for Codex-style conversation interfaces.",
  "type": "module",
  "main": "./dist/codex-ui.umd.cjs",
  "module": "./dist/codex-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/codex-ui.js",
      "require": "./dist/codex-ui.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.build.json",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  }
}
